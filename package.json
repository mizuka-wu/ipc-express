{
  "name": "@mizuka-wu/ipc-express",
  "version": "0.4.3",
  "author": "mizuka.wu <mizuka.wu@outlook.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/mizuka-wu/ipc-express.git"
  },
  "description": "This package enables you to use the electron ipc like an express application without the http overhead.",
  "main": "build/cjs/index.js",
  "module": "build/esm/index.js",
  "types": "build/cjs/index.d.ts",
  "exports": {
    ".": {
      "require": {
        "types": "./build/cjs/index.d.ts",
        "default": "./build/cjs/index.js"
      },
      "import": {
        "types": "./build/esm/index.d.ts",
        "default": "./build/esm/index.js"
      }
    },
    "./client": {
      "require": {
        "types": "./build/cjs/client/index.d.ts",
        "default": "./build/cjs/client/index.js"
      },
      "import": {
        "types": "./build/esm/client/index.d.ts",
        "default": "./build/esm/client/index.js"
      }
    },
    "./server": {
      "require": {
        "types": "./build/cjs/server/index.d.ts",
        "default": "./build/cjs/server/index.js"
      },
      "import": {
        "types": "./build/esm/server/index.d.ts",
        "default": "./build/esm/server/index.js"
      }
    }
  },
  "scripts": {
    "build": "pnpm exec rolldown -c rolldown.config.mjs && pnpm run build:types",
    "build:types": "tsc --emitDeclarationOnly --outDir build/cjs --declaration --declarationMap && tsc --emitDeclarationOnly --outDir build/esm --declaration --declarationMap --module esnext",
    "dev": "pnpm exec rolldown -c rolldown.config.mjs --watch",
    "test": "jest",
    "type-check": "tsc --noEmit",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "keywords": [
    "ipc",
    "electron",
    "express"
  ],
  "license": "MIT",
  "files": [
    "build",
    "index.d.ts",
    "README.md"
  ],
  "dependencies": {
    "nanoid": "^5.0.7",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@babel/types": "^7.10.5",
    "rolldown": "^1.0.0-rc.9",
    "@types/express": "^4.17.7",
    "@types/jest": "^26.0.4",
    "@types/node": "^12.12.50",
    "@typescript-eslint/eslint-plugin": "^3.6.1",
    "@typescript-eslint/parser": "^3.6.1",
    "electron": "^29.3.0",
    "electron-mock-ipc": "^0.3.6",
    "eslint": "^7.4.0",
    "eslint-plugin-import": "^2.22.0",
    "express": "^4.17.1",
    "husky": "^4.2.5",
    "jest": "^26.1.0",
    "lint-staged": "^10.2.11",
    "prettier": "^2.0.5",
    "rimraf": "^3.0.2",
    "ts-jest": "^26.1.3",
    "ts-node": "^8.10.2",
    "typescript": "^5.3.3",
    "vitepress": "^1.0.0"
  }
}
